# ==============================================================================
#  INSTRUCCIONES PARA TI (Y PARA TU AGENTE DE IA: CLAUDE CODE / ANTIGRAVITY…)
# ------------------------------------------------------------------------------
#  1. Copia este archivo y renombralo como ".env" en este mismo directorio.
#     (Alternativa sin tocar archivos: arranca la app y usa la pestaña de
#      Configuración — el wizard guarda las claves aquí por ti.)
#  2. Rellena las siguientes claves API indispensables:
#     - GEMINI_API_KEY: Consigue tu clave gratis en Google AI Studio. Es necesaria
#       para los embeddings (gemini-embedding-2) y modelos de Google.
#     - DEEPSEEK_API_KEY: Consigue tu clave en la plataforma de DeepSeek para usar
#       el chat ultra-barato y el modo de pensamiento/razonamiento en vivo.
#     - RAG_TOKEN: Genera un token aleatorio y seguro para proteger tu API local
#       (instrucción de generación al final de este archivo).
#  3. Si usas un agente de IA, puedes proveerle tus claves y él se encargará
#     de renombrar este archivo a ".env" y rellenar los campos por ti.
# ==============================================================================
#  .env.example — PLANTILLA DE CONFIGURACIÓN LOCAL (sin secretos reales)
# ==============================================================================

# --- Embeddings: Google AI Studio (Gemini Embedding 2, multimodal) ---
GEMINI_API_KEY=tu_api_key_de_ai_studio
# Proveedor de embeddings: gemini (cloud, default) | ollama (LOCAL, requiere GPU decente;
# modelos: bge-m3, qwen3-embedding… ajusta EMBED_MODEL y EMBED_DIM al modelo elegido).
# ¡OJO! El modelo queda CASADO con tu corpus (embed_manifest.json): cambiarlo después
# obliga a borrar qdrant_data/ y re-indexar TODO.
EMBED_PROVIDER=gemini
EMBED_MODEL=gemini-embedding-2
EMBED_DIM=1536
# Solo si EMBED_PROVIDER=ollama (servidor Ollama local):
# OLLAMA_LOCAL_URL=http://127.0.0.1:11434

# --- Qdrant LOCAL embebido (sin Docker, sin servidor) ---
QDRANT_PATH=./qdrant_data
COLLECTION_NAME=papers
# (opcional) servidor Qdrant en vez de embebido:
# QDRANT_URL=http://localhost:6333

# --- Carpetas del proyecto ---
RAW_DIR=./raw
MD_DIR=./md
OUTLINES_DIR=./outlines

# ============================================================
#  LLM de chat — MULTI-PROVEEDOR (todos cloud, eliges cuál)
#  Proveedor por defecto:  ollama | gemini | deepseek
# ============================================================
CHAT_PROVIDER=gemini

# --- Ollama Cloud (free tier; key en ollama.com/settings/keys) ---
OLLAMA_CLOUD_URL=https://ollama.com
OLLAMA_API_KEY=tu_api_key_de_ollama
OLLAMA_MODEL=gemma4:31b-cloud

# --- Gemini chat (misma key de AI Studio de arriba sirve) ---
# Ids válidos: gemini-3.5-flash | gemini-flash-latest | gemini-3-pro-preview
# OJO: gemini-3-flash NO existe.
GEMINI_CHAT_MODEL=gemini-3.5-flash

# --- DeepSeek (OpenAI-compatible). SIN VISIÓN: solo explicador de texto ---
# Modelos vigentes: deepseek-v4-flash (barato) | deepseek-v4-pro (más capaz).
# OJO: deepseek-chat / deepseek-reasoner se DEPRECAN el 2026-07-24.
DEEPSEEK_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=tu_api_key_de_deepseek
DEEPSEEK_MODEL=deepseek-v4-pro

# --- Modelo de visión para DESCRIBIR FIGURAS al ingerir ---
# bedrock (Claude Sonnet, DE PAGO, mejor calidad) | gemini (free tier, misma key de
# arriba) | manual (SIN API: la ingesta deja las figuras pendientes con instrucciones
# en descripciones/<doc>_PENDIENTES/DESCRIBIR_FIGURAS.md para que tu agente de IA
# —Claude Code, Antigravity— las describa gratis). DeepSeek NO sirve aquí.
VISION_PROVIDER=bedrock
VISION_MODEL=gemma4:31b

# --- Amazon Bedrock (Claude Sonnet 4.6, con visión) para describir figuras/tablas ---
# Autenticación por API KEY de Bedrock (token bearer). Va SOLO en el .env real.
AWS_BEARER_TOKEN_BEDROCK=tu_api_key_de_bedrock
AWS_REGION=us-east-1
# Sonnet en Bedrock se invoca por INFERENCE PROFILE (prefijo us.), no por el id pelado.
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# --- Fallback web (buscar cuando el documento no cubre la pregunta) ---
# Gemini grounding con Google Search. on|off
WEB_FALLBACK=on

# --- Backend FastAPI (corre local) ---
# Token que el cliente envía (Authorization: Bearer ...). Genéralo con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
RAG_TOKEN=genera_un_token_largo_aleatorio
RAG_PORT=8901
